# LLM API 配置（通用，支持任意 OpenAI 兼容接口）
# 旧名称（QWEN_KEY/QWEN_URL）仍兼容
LLM_KEY=sk-xxx
LLM_URL=https://api.openai.com/v1
LLM_MODEL=gpt-3.5-turbo
EMBEDDING_MODEL=text-embedding-ada-002

# Flask 服务配置
FLASK_HOST=0.0.0.0
FLASK_PORT=8000
FLASK_DEBUG=false

# 向量数据库配置
VECTOR_DB_PATH=./data/vector_store

# 知识库路径
ASSEMBLY_KB_PATH=./data/xxx.xlsx
LITERATURE_KB_PATH=./data/xxx.xlsx

# 外部 API 配置
# 高德地图 API Key（天气查询等功能使用）
# 申请地址：https://console.amap.com/dev/key/app
AMAP_KEY=your-amap-key-here

# 日志配置
LOG_LEVEL=INFO
DEBUG_MODE=false
